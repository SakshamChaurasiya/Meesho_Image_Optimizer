# MongoDB Connection URI (Required)
MONGODB_URI=mongodb://localhost:27017/packoptima

# Pino logging config (optional: debug | info | warn)
LOG_LEVEL=debug

# --- Future configuration keys (to be filled during subsequent phases) ---
# Cloudinary (Phase 3)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=



# Upstash Redis / Redis URL (Phase 6)
REDIS_URL=
